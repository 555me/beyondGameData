  "cleaning_test": {
    "activityId": "cleaning_test",
    "stageList": {
      "cleaning_test_1": {
        "desc": {
          "cn": "蟠兽顽皮，在各处留下了痕迹，虽然爪印十分可爱，但污渍也是实打实的，还是快快清理干净吧！",
          "en": "A naughty pantailbeast has left plenty of stains. The tiny paw prints are cute but the stains are very real as well. In any case, we should clean them up ASAP!"
        },
        "levelId": "",
        "mapJumpId": "",
        "missionId": "a1m6d1",
        "name": {
          "cn": "小兽留痕",
          "en": "Critters' Trail"
        },
        "questId": "",
        "rankRelatedId": "",
        "rewardId": "reward_cleaning_a1d1",
        "sortId": "1",
        "timeOffset": "0"
      },
      "cleaning_test_2": {
        "desc": {
          "cn": "实际上，驮兽十分聪明，尤其是学生们饲养的驮兽。我们有理由怀疑，它们弄脏自己就是为了爽快地洗一个冷水澡。",
          "en": "Burdenbeasts are actually quite smart, especially those raised by Tianshi disciples. We suspect they get themselves dirty on purpose just to get a proper hose-down."
        },
        "levelId": "",
        "mapJumpId": "",
        "missionId": "a1m6d2",
        "name": {
          "cn": "冷水澡",
          "en": "Cold Shower"
        },
        "questId": "",
        "rankRelatedId": "",
        "rewardId": "reward_cleaning_a1d2",
        "sortId": "2",
        "timeOffset": "0"
      },
      "cleaning_test_3": {
        "desc": {
          "cn": "高墙上的污痕着实令人压抑，在影响到大家的心情前，请将它清理干净吧。",
          "en": "The stains on the high walls look very depressing. Clean them up before anyone gets affected."
        },
        "levelId": "",
        "mapJumpId": "",
        "missionId": "a1m6d3",
        "name": {
          "cn": "污云压城",
          "en": "Reign of Gloomy Dirt"
        },
        "questId": "",
        "rankRelatedId": "",
        "rewardId": "reward_cleaning_a1d3",
        "sortId": "3",
        "timeOffset": "40"
      },
      "cleaning_test_4": {
        "desc": {
          "cn": "荣誉天师，城市形象大使，环带吉祥物大赛冠军必须时时刻刻清清爽爽！",
          "en": "The Honorary Tianshi, mascot of Wuling City, and ultimate winner of the Band Mascot Championships must be sparkling clean at all times!"
        },
        "levelId": "",
        "mapJumpId": "",
        "missionId": "a1m6d4",
        "name": {
          "cn": "拯救龙泡泡",
          "en": "Chubby Lung Rescue"
        },
        "questId": "",
        "rankRelatedId": "",
        "rewardId": "reward_cleaning_a1d4",
        "sortId": "4",
        "timeOffset": "64"
      },
      "cleaning_test_5": {
        "desc": {
          "cn": "并非只有直观可见的污渍才需清理，不可见的顽垢亦是隐患。",
          "en": "Visible stains must be cleaned. Invisible stains are hidden risks and should be rinsed as well."
        },
        "levelId": "",
        "mapJumpId": "",
        "missionId": "a1m6d5",
        "name": {
          "cn": "不可见隐患",
          "en": "Hidden Danger"
        },
        "questId": "",
        "rankRelatedId": "",
        "rewardId": "reward_cleaning_a1d5",
        "sortId": "5",
        "timeOffset": "88"
      },
      "cleaning_test_6": {
        "desc": {
          "cn": "您高速冲洗各类污渍的事迹已在武陵环卫职工之间广泛传播，他们期待一场完美的清污演练。",
          "en": "All the urban sanitation workers in Wuling are talking about your impressive high-speed cleaning feats. They are looking forward to your perfect performance in the cleaning drill."
        },
        "levelId": "",
        "mapJumpId": "jump_activity_cleaning_stage_6",
        "missionId": "a1m6d6",
        "name": {
          "cn": "平台清污演练",
          "en": "Platform Cleaning Drill"
        },
        "questId": "",
        "rankRelatedId": "activity_qingxi_qiangti_6",
        "rewardId": "reward_cleaning_a1d6",
        "sortId": "6",
        "timeOffset": "112"
      },
      "cleaning_test_7": {
        "desc": {
          "cn": "武陵良好市容的基础在于环卫职工们每一日反反复复地清洁打扫，如今您的奉献成为了这基础的一部分。",
          "en": "The daily toil of the urban sanitation workers forms the foundation of Wuling's pristine urban garden. Your contribution adds a brick to that foundation."
        },
        "levelId": "",
        "mapJumpId": "jump_activity_cleaning_stage_6",
        "missionId": "a1m6d7",
        "name": {
          "cn": "弹性清洁演练",
          "en": "Bouncy Cleaning Drill"
        },
        "questId": "",
        "rankRelatedId": "activity_qingxi_qiangti_7",
        "rewardId": "reward_cleaning_a1d7",
        "sortId": "7",
        "timeOffset": "136"
      }
    }
  },
  "dungeon_fighting": {
    "activityId": "dungeon_fighting",
    "stageList": {
      "dungeon_fighting_1": {
        "desc": {
          "cn": "“第一课！物以类聚，人以群分，兽……呃……虫……呃……总之有共性的生物往往会聚集在一处……”",
          "en": "\"Lesson ONE! Like draws like! People naturally settle into tribes! While beasts and bugs ... into ... uhm... Whatever! Critters that look the same tend to gather...\""
        },
        "levelId": "dung01_actmonster01",
        "mapJumpId": "",
        "missionId": "a1m2",
        "name": {
          "cn": "物以类聚",
          "en": "Like Draws Like"
        },
        "questId": "a1m2_q#Day1",
        "rankRelatedId": "",
        "rewardId": "reward_dungeon_actmonster_a1d1",
        "sortId": "1",
        "timeOffset": "0"
      },
      "dungeon_fighting_2": {
        "desc": {
          "cn": "“第二课！当‘野兽’视你为敌人，请您必须严肃待之！最大火力，不要手下留情！”",
          "en": "\"Lesson TWO! If the 'wild things' treat you as an enemy, deal with it seriously! MAX the firepower! No mercy!\""
        },
        "levelId": "dung01_actmonster02",
        "mapJumpId": "",
        "missionId": "a1m2",
        "name": {
          "cn": "爆破练习",
          "en": "Explosion Practice"
        },
        "questId": "a1m2_q#Day2",
        "rankRelatedId": "",
        "rewardId": "reward_dungeon_actmonster_a1d2",
        "sortId": "2",
        "timeOffset": "0"
      },
      "dungeon_fighting_3": {
        "desc": {
          "cn": "“第三课！巧妙利用大自然的残酷，无论生命还是死亡，起始与终结都可以利用。”",
          "en": "\"Lesson THREE! Leverage nature's fickle cruelty! Life and death! The beginning and the end! Everything can be used!\""
        },
        "levelId": "dung01_actmonster03",
        "mapJumpId": "",
        "missionId": "a1m2",
        "name": {
          "cn": "虫海求生",
          "en": "Outlast the Bugs"
        },
        "questId": "a1m2_q#Day3",
        "rankRelatedId": "",
        "rewardId": "reward_dungeon_actmonster_a1d3",
        "sortId": "3",
        "timeOffset": "40"
      },
      "dungeon_fighting_4": {
        "desc": {
          "cn": "“第四课！取舍。大自然向您展示的信息是复杂的，您需要取舍，请高效安排处理事务的顺序。”",
          "en": "\"LESSON FOUR! Prioritize! Nature shows you a huge mess of info. You gotta choose what to engage in and prioritize task sequences.\""
        },
        "levelId": "dung01_actmonster04",
        "mapJumpId": "",
        "missionId": "a1m2",
        "name": {
          "cn": "多向爆破",
          "en": "Coordinated Demolishing"
        },
        "questId": "a1m2_q#Day4",
        "rankRelatedId": "",
        "rewardId": "reward_dungeon_actmonster_a1d4",
        "sortId": "4",
        "timeOffset": "64"
      },
      "dungeon_fighting_5": {
        "desc": {
          "cn": "“第五课！观察。无论是扎营，还是狩猎，选好您的目标，当然，也要选好您的邻居。”",
          "en": "\"LESSON FIVE! Observe! Select a proper target when camping or hunting. And pitch your tent next to proper neighbors.\""
        },
        "levelId": "dung01_actmonster05",
        "mapJumpId": "",
        "missionId": "a1m2",
        "name": {
          "cn": "恶邻",
          "en": "Bad Neighbor"
        },
        "questId": "a1m2_q#Day5",
        "rankRelatedId": "",
        "rewardId": "reward_dungeon_actmonster_a1d5",
        "sortId": "5",
        "timeOffset": "88"
      },
      "dungeon_fighting_6": {
        "desc": {
          "cn": "“第六课！宣称。向眼前的一切，宣告您的领地范围，消灭入侵者！”",
          "en": "\"LESSON SIX! Declaration! Announce your territories to everything! And yes, neutralize the intruders!\""
        },
        "levelId": "dung01_actmonster06",
        "mapJumpId": "",
        "missionId": "a1m2",
        "name": {
          "cn": "城堡准则",
          "en": "Castle Doctrine"
        },
        "questId": "a1m2_q#Day6",
        "rankRelatedId": "",
        "rewardId": "reward_dungeon_actmonster_a1d6",
        "sortId": "6",
        "timeOffset": "112"
      },
      "dungeon_fighting_7": {
        "desc": {
          "cn": "“第七课！自视。请在之前学到的野性知识中，回忆起您人类的身份，分析这头凶暴野兽的弱点，击败它！”",
          "en": "\"LESSON SEVEN! Self-awareness! I know you took plenty of wilderness knowledge courses, but remember that you're a bipedal sapient! Analyze the weak points of this feral critter and defeat it!\""
        },
        "levelId": "dung01_actmonster07",
        "mapJumpId": "",
        "missionId": "a1m2",
        "name": {
          "cn": "野性苦果",
          "en": "Feral Gall"
        },
        "questId": "a1m2_q#Day7",
        "rankRelatedId": "",
        "rewardId": "reward_dungeon_actmonster_a1d7",
        "sortId": "7",
        "timeOffset": "136"
      },
      "dungeon_fighting_8": {
        "desc": {
          "cn": "“那么，最终考核现在开始，请您尽力而为。”",
          "en": "\"Well, the final assessment is starting now. Do not push yourself too hard.\""
        },
        "levelId": "dung01_actmonster08",
        "mapJumpId": "",
        "missionId": "a1m2",
        "name": {
          "cn": "最终考核",
          "en": "Final Assessment"
        },
        "questId": "a1m2_q#Day7",
        "rankRelatedId": "dung01_actmonster08",
        "rewardId": "reward_dungeon_actmonster_a1d8",
        "sortId": "8",
        "timeOffset": "136"
      }
    }
  }
}